{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start --host 0.0.0.0",
    "build": "node scripts/fetch-releases.js && node scripts/generate-llm-docs.js && docusaurus build",
    "swizzle": "docusaurus swizzle --danger",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "serve:i18n": "pnpm build && docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids"
  },
  "dependencies": {
    "@codesandbox/sandpack-react": "^2.19.0",
    "@docusaurus/core": "3.9.2",
    "@docusaurus/faster": "3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@egjs/flicking": "workspace:~",
    "@egjs/flicking-plugins": "workspace:~",
    "@egjs/react-flicking": "workspace:~",
    "@egjs/react-grid": "^1.1.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mdx-js/react": "^3.0.0",
    "@mui/material": "^6.4.12",
    "bulma": "^0.9.2",
    "clsx": "^1.1.1",
    "docusaurus-plugin-sass": "0.2.6",
    "prism-react-renderer": "^2.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-tabs": "^3.2.2",
    "react-toggle": "^4.1.2"
  },
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@docusaurus/types": "3.9.2",
    "@types/react": "^18.3.1",
    "remark-breaks": "^4.0.0",
    "tslib": "^2.2.0",
    "typescript": "~5.6.0"
  }
