{
  "name": "@egjs/react-flicking",
  "version": "4.15.0",
  "description": "Everyday 30 million people experience. It's reliable, flexible and extendable carousel.",
  "main": "dist/flicking.cjs.js",
  "module": "dist/flicking.esm.js",
  "sideEffects": [
    "**/*.css",
    "**/*.sass"
  ],
  "es2015": "dist/flicking.esm.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "vite --config vite.dev.config.ts",
    "dev:preview": "vite --config vite.dev.config.ts --mode production",
    "build": "run-s build:bundle build:declaration postbuild",
    "build:bundle": "rm -rf ./dist && concurrently \"VITE_BUILD_FORMAT=esm vite build\" \"VITE_BUILD_FORMAT=cjs vite build\" \"VITE_BUILD_FORMAT=umd vite build\"",
    "postbuild": "cpx 'node_modules/@egjs/flicking/dist/*.{css,css.map}' dist/",
    "build:declaration": "tsc -p tsconfig.declaration.json"
  },
  "dependencies": {
    "@cfcs/core": "^0.1.0",
    "@cfcs/react": "^0.1.0",
    "@egjs/component": "^3.0.2",
    "@egjs/flicking": "workspace:~",
    "@egjs/list-differ": "^1.0.1"
  },
  "devDependencies": {
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@egjs/build-helper": "0.0.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/material": "^7.1.1",
    "@types/highlight.js": "^9.12.3",
    "@types/node": "12.0.0",
    "@types/react": "^18.0.5",
    "@types/react-dom": "16.8.4",
    "@types/react-is": "^17.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitejs/plugin-vue": "^6.0.4",
    "cpx": "^1.5.0",
    "highlight.js": "^9.15.6",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.3.0",
    "rollup": "^2.45.2",
    "tslib": "^2.2.0",
    "typescript": "4.8.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/naver/egjs-flicking/tree/master/packages/react-flicking"
  },
  "author": {
    "name": "NAVER Corp."
  },
  "namespace": {
    "eg": "eg"
  },
  "homepage": "https://naver.github.io/egjs-flicking",
  "bugs": {
    "url": "https://github.com/naver/egjs-flicking/issues"
  },
  "license": "MIT"
}
