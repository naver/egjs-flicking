{
  "name": "@egjs/root",
  "private": true,
  "version": "3.0.0",
  "description": "Everyday 30 million people experience. It's reliable, flexible and extendable carousel.",
  "sideEffects": [
    "**/*.css",
    "**/*.sass"
  ],
  "scripts": {
    "prepare": "husky",
    "clean:all": "pnpm -r --include-workspace-root exec -- rm -rf node_modules",
    "reinstall": "pnpm clean:all && pnpm install",
    "dev:flicking": "pnpm --filter @egjs/flicking dev",
    "dev:react": "pnpm --filter @egjs/react-flicking dev",
    "dev:vue": "pnpm --filter @egjs/vue3-flicking dev",
    "dev:plugins": "pnpm --filter @egjs/flicking-plugins dev",
    "dev:all": "concurrently -n \"flicking,react,vue,plugins\" -c \"blue,green,yellow,magenta\" \"pnpm dev:flicking\" \"pnpm dev:react\" \"pnpm dev:vue\" \"pnpm dev:plugins\"",
    "preview": "run-s preview:build preview:run",
    "preview:build": "pnpm publish:build",
    "preview:run": "concurrently -n \"flicking,react,vue,plugins\" -c \"blue,green,yellow,magenta\" \"pnpm --filter flicking dev:preview\" \"pnpm --filter react-flicking dev:preview\" \"pnpm --filter vue3-flicking dev:preview\" \"pnpm --filter flicking-plugins dev:preview\"",
    "test": "pnpm --filter @test/unit test",
    "test:plugins": "pnpm --filter @test/plugins test",
    "test:cfc": "pnpm --filter @test/cfc test",
    "test:e2e": "pnpm --filter @test/e2e test",
    "test:all": "pnpm test && pnpm test:plugins && pnpm test:cfc",
    "lint": "biome check packages/",
    "lint:fix": "biome check --write packages/",
    "format": "biome format --write packages/",
    "api-docs:generate": "pnpm --filter flicking build:declaration && pnpm --filter @egjs/flicking-plugins build:declaration && api-extractor run -c packages/flicking/api-extractor.json --local && api-extractor run -c packages/flicking-plugins/api-extractor.json --local && pnpm --filter api-docs-generator generate",
    "api-docs:docusaurus": "pnpm --filter flicking build:declaration && pnpm --filter @egjs/flicking-plugins build:declaration && api-extractor run -c packages/flicking/api-extractor.json --local && api-extractor run -c packages/flicking-plugins/api-extractor.json --local && pnpm --filter api-docs-generator generate:docusaurus",
    "docs:build": "pnpm api-docs:docusaurus && pnpm --filter docs build",
    "docs:serve": "pnpm --filter docs serve",
    "docs:deploy": "pnpm docs:build && gh-pages -d packages/docs/build --add --remote upstream",
    "docs:deploy-origin": "pnpm docs:build && gh-pages -d packages/docs/build --add --remote origin",
    "coveralls": "cat ./coverage/lcov.info | ./node_modules/coveralls/bin/coveralls.js",
    "publish:version": "node config/sync-version.js",
    "publish:build": "pnpm -r --filter=@egjs/flicking --filter=@egjs/flicking-plugins --filter=@egjs/react-flicking --filter=@egjs/vue3-flicking run build",
    "publish:stable": "pnpm publish:build && pnpm -r publish --no-git-checks --filter=!docs --filter=!@test/* --filter=!@egjs/root",
    "publish:stable:flicking": "pnpm --filter @egjs/flicking build && pnpm --filter @egjs/flicking publish --no-git-checks",
    "publish:stable:react": "pnpm --filter @egjs/react-flicking build && pnpm --filter @egjs/react-flicking publish --no-git-checks",
    "publish:stable:vue": "pnpm --filter @egjs/vue3-flicking build && pnpm --filter @egjs/vue3-flicking publish --no-git-checks",
    "publish:stable:plugins": "pnpm --filter @egjs/flicking-plugins build && pnpm --filter @egjs/flicking-plugins publish --no-git-checks",
    "publish:beta": "pnpm publish:build && pnpm -r publish --no-git-checks --tag beta --filter=!docs --filter=!@test/* --filter=!@egjs/root",
    "publish:beta:flicking": "pnpm --filter @egjs/flicking build && pnpm --filter @egjs/flicking publish --no-git-checks --tag beta",
    "publish:beta:react": "pnpm --filter @egjs/react-flicking build && pnpm --filter @egjs/react-flicking publish --no-git-checks --tag beta",
    "publish:beta:vue": "pnpm --filter @egjs/vue3-flicking build && pnpm --filter @egjs/vue3-flicking publish --no-git-checks --tag beta",
    "publish:beta:plugins": "pnpm --filter @egjs/flicking-plugins build && pnpm --filter @egjs/flicking-plugins publish --no-git-checks --tag beta",
    "release": "node config/release.js",
    "release:dry-run": "node config/release.js --dry-run"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/naver/egjs-flicking"
  },
  "author": {
    "name": "NAVER Corp."
  },
  "homepage": "https://naver.github.io/egjs-flicking/",
  "bugs": {
    "url": "https://github.com/naver/egjs-flicking/issues"
  },
  "license": "MIT",
  "browserslist": [
    "last 2 version",
    "ie 9-11",
    "not op_mini all"
  ],
  "keywords": [
    "carousel",
    "flicking",
    "slider",
    "mouse",
    "touch",
    "desktop",
    "mobile",
    "react",
    "vue",
    "angular",
    "preact",
    "gallery",
    "slideshow",
    "swipe",
    "egjs"
  ],
  "devDependencies": {
    "@babel/preset-env": "^7.16.0",
    "@biomejs/biome": "2.3.11",
    "@egjs/flicking-plugins": "~4.7.1",

    "@microsoft/api-extractor": "^7.55.1",
    "@rollup/plugin-babel": "^5.3.0",
    "@rollup/plugin-commonjs": "^11.1.0",
    "@rollup/plugin-node-resolve": "^7.1.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@types/fs-extra": "^9.0.11",
    "@types/node": "^14.14.35",
    "@types/resize-observer-browser": "^0.1.6",
    "autoprefixer": "^9.8.8",
    "babel-loader": "^8.2.2",
    "babel-preset-env": "^1.7.0",
    "concurrently": "^6.0.0",
    "core-js": "^3.9.1",
    "coveralls": "^3.0.2",
    "cpx": "^1.5.0",
    "fs-extra": "^7.0.1",
    "gh-pages": "^2.0.1",
    "husky": "^9.1.7",
    "npm-run-all": "^4.1.5",
    "postcss-clean": "^1.2.2",
    "postcss-cli": "^7.1.2",
    "print-coveralls": "^1.2.2",
    "print-sizes": "0.0.3",
    "pvu": "^0.6.1",
    "rollup": "^2.41.5",
    "rollup-plugin-livereload": "^1.3.0",
    "rollup-plugin-postcss": "^3.1.3",
    "rollup-plugin-prototype-minify": "^1.1.0",
    "rollup-plugin-serve": "^1.1.0",
    "rollup-plugin-terser": "^7.0.2",
    "rollup-plugin-typescript2": "^0.36.0",
    "rollup-plugin-visualizer": "^4.2.1",
    "sass": "^1.79.3",
    "sync-exec": "^0.6.2",
    "terser": "^5.44.1",
    "ts-mock-imports": "^1.3.3",
    "tsconfig-paths-webpack-plugin": "^3.5.1",
    "tslib": "^2.1.0",
    "ttypescript": "^1.5.12",
    "typescript": "^3.9.10",
    "typescript-transform-paths": "^2.2.3",
    "vite": "^7.2.6",
    "vite-plugin-dts": "^4.5.4"
  },
  "pnpm": {}
}
